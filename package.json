{
  "name": "time-counter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "turbo build",
    "build:pages": "pnpm run build && rm -rf dist && mkdir -p dist && cp -R apps/landing/dist/. dist/ && for app in apps/*; do app_name=$(basename \"$app\"); if [ \"$app_name\" = \"landing\" ]; then continue; fi; if [ -d \"$app/dist\" ]; then mkdir -p \"dist/$app_name\"; cp -R \"$app/dist/.\" \"dist/$app_name/\"; fi; done && touch dist/.nojekyll",
    "test:e2e": "pnpm --filter @time-calculator/e2e test"
  },
  "pnpm": {
    "overrides": {
      "cookie": "^0.7.2",
      "tar": ">=7.5.11",
      "flatted": ">=3.4.2",
      "undici": ">=7.24.0",
      "picomatch": "4.0.4",
      "path-to-regexp@^0": ">=0.1.13",
      "path-to-regexp@^8": ">=8.4.0",
      "hono": ">=4.12.21",
      "devalue": ">=5.8.1",
      "brace-expansion@^5": ">=5.0.6",
      "yaml": "2.8.3",
      "serialize-javascript": ">=7.0.5",
      "@hono/node-server": ">=1.19.13",
      "vite@^7": ">=7.3.2",
      "vite@^8": ">=8.0.5",
      "follow-redirects": ">=1.16.0",
      "uuid": ">=14.0.0",
      "esbuild": ">=0.28.1",
      "shell-quote": ">=1.8.4",
      "ws": ">=8.20.1",
      "qs": ">=6.15.2",
      "webpack-dev-server": ">=5.2.4",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "fast-uri": ">=3.1.2",
      "ip-address": ">=10.1.1",
      "postcss": ">=8.5.10"
    }
  },
  "devDependencies": {
    "turbo": "^2.9.14"
  }
}
